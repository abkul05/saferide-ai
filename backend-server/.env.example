PORT=5000
NODE_ENV=development
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/saferide?retryWrites=true&w=majority
JWT_SECRET=your_jwt_access_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here
FIREBASE_PROJECT_ID=saferide-ai-firebase-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@saferide-ai.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_USE_MOCK=true
